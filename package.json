{
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "preview": "turbo run preview",
    "test": "turbo run test",
    "prepare": "husky",
    "clean": "turbo run clean && rm -rf node_modules",
    "powersync:up": "docker compose --env-file powersync/docker/.env.dev -f powersync/docker/docker-compose.dev.yaml up -d",
    "powersync:down": "docker compose --env-file powersync/docker/.env.dev -f powersync/docker/docker-compose.dev.yaml down",
    "powersync:logs": "docker compose --env-file powersync/docker/.env.dev -f powersync/docker/docker-compose.dev.yaml logs -f",
    "gen-types": "supabase gen types --lang=typescript --local > packages/common/types/database.ts"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx,css,scss,html,md,json}": "prettier --ignore-unknown --write --semi=false",
    "apps/web/**/*.{js,ts,jsx,tsx}": "eslint --fix --max-warnings 0",
    "packages/ui/**/*.{ts,tsx,js,jsx,css,scss,html,md,json}": "prettier --ignore-unknown --write --semi=false",
    "packages/ui/**/*.{js,ts,jsx,tsx}": "eslint --fix --max-warnings 0"
  },
  "prettier": {
    "semi": false,
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@nasti/eslint-config": "workspace:*",
    "eslint": "^9.11.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.0.0"
  },
  "peerDependencies": {
    "@types/react": "^19.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "resolutions": {
    "@types/react": "^19.0.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "0.32.6",
    "sharp-ico": "0.1.5"
  },
  "packageManager": "pnpm@8.10.5"
}
